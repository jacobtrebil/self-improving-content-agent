# OS noise
.DS_Store

# Claude Code runtime state
.claude/scheduled_tasks.lock

# ─── SECRETS — this is a PUBLIC repo; never commit credentials ───────────────
# LangSmith API key → .env (LANGSMITH_API_KEY). Postiz channel IDs →
# config/posting.local.yaml. Broad patterns below are belt-and-suspenders so a
# secret can't slip in from any directory.
config/*.local.yaml
*.local.yaml
*.local.json
.env
.env.*
!.env.example
*.key
*.pem
*credentials*
*secret*
# Committed templates that are intentionally safe (no real values):
!config/observability.example.yaml

# Local-only operational records — live post IDs from schedule runs
vibe-carousels/scheduled_*.tsv
vibe-carousels/*.local.tsv

# Dashboard outputs — raw API dumps (contain channel/post IDs) + rendered view
dashboard/data/
dashboard/dashboard.html
# Manually-logged posts the Postiz API doesn't return (live metrics, local-only)
dashboard/*.local.tsv

# Traces: the top-level traces/ stream is the repo-wide run log (mostly
# duplicates of the per-campaign copies + non-campaign runs) — keep the folder,
# the example, and the README; ignore live run files.
traces/*.jsonl
!traces/example-run.jsonl

# Campaigns: commit briefs/specs/decisions + results; never the live post IDs.
# Per-campaign traces/ ARE committed — they record how each batch was produced.
campaigns/**/scheduled.tsv
# rendered/ holds local build outputs + symlinks to gitignored media — keep the
# folder, ignore its contents.
campaigns/**/rendered/*
!campaigns/**/rendered/.gitkeep

# Media never enters the public repo.
# Bulk assets and finals live in ../slideshows-media (symlinked below);
# per-deck slide PNGs / ai-bg PNGs are render outputs, regenerated locally.
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.mp4
*.mov
*.MOV

# Symlinks into the private ../slideshows-media folder
/Vibe Health Assets
/vibe-carousels/reels
/vibe-carousels/shorts
/vibe-carousels/animal-transformations
/vibe-carousels/_backup_bfaf_originals
